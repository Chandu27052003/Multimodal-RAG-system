# =============================================================
# Multimodal RAG System - Environment Configuration
# =============================================================
# Copy this file to .env and fill in the values

# ---------- Service Ports ----------
GATEWAY_PORT=8000
INGESTION_PORT=8001
PREPROCESSING_PORT=8002
EMBEDDING_PORT=8003
VECTOR_STORE_PORT=8004
RETRIEVAL_PORT=8005
GENERATION_PORT=8006

# ---------- NVIDIA NIM API ----------
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---------- Model Configuration (NVIDIA NIM) ----------
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
RERANKING_MODEL=nv-rerank-qa-mistral-4b:1
GENERATION_MODEL=qwen/qwen2-7b-instruct

# ---------- Vector Database ----------
VECTOR_DB_TYPE=chromadb
VECTOR_DB_PATH=./data/vector_db

# ---------- File Storage ----------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=100

# ---------- Chunking Configuration ----------
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ---------- Retrieval Configuration ----------
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# ---------- Deepgram Speech-to-Text ----------
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=nova-2

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_DIR=./logs
